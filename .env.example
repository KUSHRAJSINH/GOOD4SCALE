
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX     # The trial number from Twilio console

# ── Google Gemini ───────
GOOGLE_API_KEY=AIzaSy_your_gemini_api_key_here


# This is what Twilio will call hook
BASE_URL=https://your-static-domain.ngrok-free.app



NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# "base" is recommended — fast enough for demos, good accuracy
WHISPER_MODEL=base

# Full list: edge-tts --list-voices
EDGE_TTS_VOICE=en-US-JennyNeural
